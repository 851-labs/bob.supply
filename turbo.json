{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["BOB_AVATARS_BATCH_ID", "BOB_AVATARS_CODEX_MODEL", "PORT", "NODE_ENV"]
    }
  }
}
