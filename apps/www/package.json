{
  "name": "@bob-supply/www",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build && wrangler dev --config .output/server/wrangler.json --remote",
    "dev:vite": "vp dev",
    "build": "vp build",
    "deploy": "wrangler deploy --config .output/server/wrangler.json",
    "preview": "vp preview",
    "test": "vp test run",
    "typegen": "bun run build && wrangler types src/worker-configuration.d.ts --config .output/server/wrangler.json --env-interface CloudflareEnv"
  },
  "dependencies": {
    "@bob-supply/core": "workspace:*",
    "@bob-supply/sdk": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "catalog:"
  }
}
