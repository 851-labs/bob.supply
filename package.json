{
  "name": "@bob-supply/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tailwindcss/vite": "4.3.0",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@tanstack/router-plugin": "1.167.35",
      "@types/bun": "1.3.14",
      "@types/node": "25.8.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "@vitejs/plugin-react": "6.0.1",
      "lefthook": "2.1.6",
      "nitro": "3.0.260429-beta",
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "tailwindcss": "4.3.0",
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "typescript": "6.0.3",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
      "vite-plus": "latest",
      "wrangler": "4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "test": "vp run -r test",
    "lint": "vp lint --type-aware --type-check",
    "lint:fix": "vp lint --fix --type-aware --type-check",
    "fmt": "vp fmt --check",
    "fmt:fix": "vp fmt",
    "plan": "bun run --cwd apps/generator plan",
    "availability": "bun run --cwd apps/generator availability",
    "generate": "bun run --cwd apps/generator generate",
    "typegen:worker": "bun run --cwd apps/www typegen",
    "upload:generated": "bun run --cwd apps/generator upload"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "lefthook": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
